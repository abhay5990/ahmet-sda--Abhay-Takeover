# ── Project Path ──────────────────────────────────────────────────────────────
# Auto-detected from repo root by deploy.sh. Override only if needed.
# PROJECT_DIR=/home/ubuntu/e-commerce-management-system

# ── Domain ────────────────────────────────────────────────────────────────────
# Used by Nginx (via deploy.sh envsubst) and Django ALLOWED_HOSTS / CSRF origins
DOMAIN=admin4gamers.com

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
# PROD: set to False and fill DOMAIN above — ALLOWED_HOSTS is derived from DOMAIN automatically
# PROD: DJANGO_SETTINGS_MODULE=config.settings.prod

# ── Database ──────────────────────────────────────────────────────────────────
# Dev default: SQLite (zero setup, no Docker needed)
DB_ENGINE=django.db.backends.sqlite3
# PROD: switch to mysql and fill the rest
# DB_ENGINE=django.db.backends.mysql
DB_NAME=inventory_manager
DB_USER=root
DB_PASSWORD=devpassword
DB_HOST=127.0.0.1
DB_PORT=3307

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Formula: 2 × CPU_cores + 1  (check with: nproc)
GUNICORN_WORKERS=3

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your-fernet-key-here
